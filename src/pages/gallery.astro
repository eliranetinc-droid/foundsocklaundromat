---
import Layout from '../components/Layout.astro';
import LocationBlock from '../components/LocationBlock.astro';
import { generateBreadcrumbSchema } from '../lib/schema';

const breadcrumbs = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://www.foundsocklaundromat.com/' },
  { name: 'Gallery', url: 'https://www.foundsocklaundromat.com/gallery' },
]);

// Real captions matching the actual photos in /public/photos/gallery/
const photos = [
  { src: '/photos/gallery/01.jpg', alt: 'Storefront — The Found Sock Laundromat at 76 Washington St, Brighton MA' },
  { src: '/photos/gallery/02.jpg', alt: 'Wide view of dryers and washers, clean and well-lit' },
  { src: '/photos/gallery/03.jpg', alt: 'LG front-load washers — 25 lb capacity, FasCard payment' },
  { src: '/photos/gallery/04.jpg', alt: 'Comfortable seating area with tables and chairs' },
  { src: '/photos/gallery/05.jpg', alt: 'LG front-load 25 lb washer signage with payment options' },
  { src: '/photos/gallery/06.jpg', alt: 'FasCard touchscreen kiosk — buy a card, load with cash or credit' },
  { src: '/photos/gallery/07.jpg', alt: 'Welcome sign on the door — store hours 6 AM to 11 PM, every day' },
  { src: '/photos/gallery/08.jpg', alt: 'FasCard payment terminals on every machine' },
  { src: '/photos/gallery/09.jpg', alt: 'Soap Center vending — detergent, bleach, fabric softener' },
  { src: '/photos/gallery/10.jpg', alt: 'Dryer wall — large capacity dryers' },
  { src: '/photos/gallery/11.jpg', alt: 'Seating and folding area' },
  { src: '/photos/gallery/12.jpg', alt: 'Storefront — daytime view' },
];
---
<Layout
  title="Photo Gallery · The Found Sock Laundromat, Brighton MA"
  description="Photos of our facility — machines, seating, folding area, and the touchscreen kiosk. See for yourself what a spotless laundromat looks like."
  extraSchemas={[breadcrumbs]}
>
  <section class="max-w-6xl mx-auto px-5 py-14 md:py-20">
    <p class="text-xs uppercase tracking-[0.25em] text-brand-blue font-bold mb-3">Gallery</p>
    <h1 class="text-5xl font-bold tracking-tight mb-10 leading-tight">See for yourself.</h1>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {photos.map((p, i) => (
        <div class="aspect-square rounded-xl overflow-hidden bg-gradient-to-br from-blue-200 to-brand-blue">
          <img src={p.src} alt={p.alt} loading={i < 3 ? 'eager' : 'lazy'} class="w-full h-full object-cover" onerror="this.style.display='none'" />
        </div>
      ))}
    </div>
  </section>
  <LocationBlock />
</Layout>
