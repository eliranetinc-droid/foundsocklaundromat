---
import { Picture, type ImageMetadata } from 'astro:assets';
import Layout from '../components/Layout.astro';
import LocationBlock from '../components/LocationBlock.astro';
import { generateBreadcrumbSchema } from '../lib/schema';

const breadcrumbs = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://www.foundsocklaundromat.com/' },
  { name: 'Gallery', url: 'https://www.foundsocklaundromat.com/gallery/' },
]);

import metadata from '../data/gallery.json';

// Glob all 24 gallery images so astro:assets can process them.
const imageModules = import.meta.glob<{ default: ImageMetadata }>('../assets/photos/gallery/*.jpg', { eager: true });
const images: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(imageModules)) {
  const filename = path.split('/').pop()!; // e.g. "01.jpg"
  images[filename] = mod.default;
}

// Match each gallery.json entry to its imported asset.
const photos = metadata
  .map((m) => {
    const filename = m.src.split('/').pop()!;
    const img = images[filename];
    return img ? { img, alt: m.alt } : null;
  })
  .filter((x): x is { img: ImageMetadata; alt: string } => x !== null);
---
<Layout
  title="Photo Gallery · The Found Sock Laundromat, Brighton MA"
  description="Photos of our facility — machines, seating, folding area, and the touchscreen kiosk. See for yourself what a spotless laundromat looks like."
  extraSchemas={[breadcrumbs]}
>
  <section class="max-w-6xl mx-auto px-5 py-14 md:py-20">
    <p class="text-xs uppercase tracking-[0.25em] text-brand-blue font-bold mb-3">Gallery</p>
    <h1 class="text-5xl font-bold tracking-tight mb-10 leading-tight">See for yourself.</h1>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {photos.map((p, i) => (
        <div class="aspect-square rounded-xl overflow-hidden bg-gradient-to-br from-blue-200 to-brand-blue">
          <Picture src={p.img} formats={['avif', 'webp']} widths={[300, 500, 700]} sizes="(max-width: 768px) 50vw, 33vw" alt={p.alt} loading={i < 2 ? 'eager' : 'lazy'} class="w-full h-full object-cover" />
        </div>
      ))}
    </div>
  </section>
  <LocationBlock />
</Layout>
