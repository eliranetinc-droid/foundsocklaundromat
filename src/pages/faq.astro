---
import Layout from '../components/Layout.astro';
import FaqList from '../components/FaqList.astro';
import LocationBlock from '../components/LocationBlock.astro';
import faqs from '../data/faqs.json';
import { generateBreadcrumbSchema, generateFaqSchema } from '../lib/schema';

const breadcrumbs = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://www.foundsocklaundromat.com/' },
  { name: 'FAQ', url: 'https://www.foundsocklaundromat.com/faq' },
]);
const faqSchema = generateFaqSchema(faqs.map(f => ({ q: f.q, a: f.a })));
---
<Layout
  title="Frequently Asked Questions · The Found Sock Laundromat, Brighton MA"
  description="Common questions about our hours, payment options, machine sizes, the FasCard app, parking, and more. Quick answers for first-time visitors."
  extraSchemas={[breadcrumbs, faqSchema]}
>
  <section class="max-w-2xl mx-auto px-5 py-14 md:py-20">
    <p class="text-xs uppercase tracking-[0.25em] text-brand-blue font-bold mb-3">Frequently asked</p>
    <h1 class="text-5xl font-bold tracking-tight mb-10 leading-tight">Questions, answered.</h1>
    <FaqList />
  </section>
  <LocationBlock />
</Layout>
