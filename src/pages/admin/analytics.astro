---
export const prerender = false;

import AdminLayout from '../../components/admin/AdminLayout.astro';
import AdminIcon from '../../components/admin/AdminIcon.astro';
import RangePicker from '../../components/admin/RangePicker.astro';
import { getHelpdeskEnv } from '../../lib/helpdesk/env';
import { viewsByDayRange, topPagesRange, topCountriesRange, deviceSplitRange, referrersRange, hoursOfDayRange, viewsInRange, recentPageviews, countRecentViewers, getTimezone, viewsByChannelRange, entryPagesRange, issueFunnelRange } from '../../lib/helpdesk/db';
import { resolveFromParams, shiftDay } from '../../lib/helpdesk/ranges';

const range = resolveFromParams(Astro.url.searchParams);

const env = await getHelpdeskEnv();
const [views, prevViews, prevTotal, pages, countries, devices, refs, hours, recent, viewingNow, tz, channels, entries, funnel] = await Promise.all([
  viewsByDayRange(env.DB, range.start, range.end), viewsByDayRange(env.DB, range.prevStart, range.prevEnd), viewsInRange(env.DB, range.prevStart, range.prevEnd),
  topPagesRange(env.DB, range.start, range.end), topCountriesRange(env.DB, range.start, range.end),
  deviceSplitRange(env.DB, range.start, range.end), referrersRange(env.DB, range.start, range.end), hoursOfDayRange(env.DB, range.start, range.end),
  recentPageviews(env.DB, 25), countRecentViewers(env.DB, 5), getTimezone(env.DB),
  viewsByChannelRange(env.DB, range.start, range.end), entryPagesRange(env.DB, range.start, range.end), issueFunnelRange(env.DB, range.start, range.end),
]);
const visitTime = (iso: string) => new Date(iso).toLocaleString('en-US', { timeZone: tz, month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });

const total = views.reduce((s, v) => s + v.views, 0);
const dailyAvg = Math.round(total / range.days);
const deltaPct = prevTotal === 0 ? (total === 0 ? 0 : 100) : Math.round(((total - prevTotal) / prevTotal) * 100);
const busiest = views.reduce((m, v) => (v.views > (m?.views ?? -1) ? v : m), null as null | { day: string; views: number });

// Gap-filled daily series for the big chart (current period)
const days: string[] = Array.from({ length: range.days }, (_, i) => shiftDay(range.start, i));
const vmap = new Map(views.map(v => [v.day, v.views]));
const series = days.map(d => vmap.get(d) ?? 0);

// Gap-filled daily series for the ghost line (previous period, same length,
// aligned day-for-day so index i in both series is "i days into the window").
const prevDays: string[] = Array.from({ length: range.days }, (_, i) => shiftDay(range.prevStart, i));
const prevVmap = new Map(prevViews.map(v => [v.day, v.views]));
const prevSeries = prevDays.map(d => prevVmap.get(d) ?? 0);

const maxDay = Math.max(1, ...series, ...prevSeries);
const W = 720, H = 180;
const toPts = (s: number[]) => s.map((v, i) => [range.days <= 1 ? 0 : (i / (range.days - 1)) * W, H - (v / maxDay) * (H - 10) - 5] as const);
const pts = toPts(series);
const prevPts = toPts(prevSeries);
const linePath = pts.map((p, i) => `${i ? 'L' : 'M'}${p[0].toFixed(1)},${p[1].toFixed(1)}`).join(' ');
const prevLinePath = prevPts.map((p, i) => `${i ? 'L' : 'M'}${p[0].toFixed(1)},${p[1].toFixed(1)}`).join(' ');
const areaPath = `M0,${H} ${pts.map(p => `L${p[0].toFixed(1)},${p[1].toFixed(1)}`).join(' ')} L${W},${H} Z`;

const maxPage = Math.max(1, ...pages.map(p => p.views));
const devTotal = Math.max(1, devices.reduce((s, d) => s + d.views, 0));
const hourArr = Array.from({ length: 24 }, (_, h) => hours.find(x => x.hour === h)?.views ?? 0);
const maxHour = Math.max(1, ...hourArr);

// Busiest weekday: aggregate the gap-filled daily series (current period) by
// UTC weekday-of the ET calendar day (noon UTC avoids any DST edge crossing).
const weekdayArr = Array.from({ length: 7 }, () => 0);
days.forEach((d, i) => {
  const wd = new Date(d + 'T12:00:00Z').getUTCDay();
  weekdayArr[wd] += series[i];
});
const maxWeekday = Math.max(1, ...weekdayArr);
const weekdayLabels = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

const maxChannel = Math.max(1, ...channels.map(c => c.views));
const channelTotal = Math.max(1, channels.reduce((s, c) => s + c.views, 0));
const maxEntry = Math.max(1, ...entries.map(e => e.n));

const label12 = (h: number) => (h === 0 ? '12a' : h < 12 ? `${h}a` : h === 12 ? '12p' : `${h - 12}p`);
---
<AdminLayout title="Analytics">
  <div class="flex items-center justify-between flex-wrap gap-3 mb-5">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-bold tracking-tight">Analytics</h1>
      {viewingNow > 0 && (
        <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-emerald-700 bg-emerald-50 px-2.5 py-1 rounded-full">
          <span class="relative flex w-2 h-2"><span class="absolute inline-flex w-full h-full rounded-full bg-emerald-400 opacity-75 animate-ping"></span><span class="relative inline-flex w-2 h-2 rounded-full bg-emerald-500"></span></span>
          {viewingNow} viewing now
        </span>
      )}
    </div>
    <RangePicker range={range} action="/admin/analytics/" />
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
    <div class="bg-white rounded-2xl border border-line p-4 shadow-sm">
      <div class="flex items-center gap-1.5 text-brand-blue/60 mb-1"><AdminIcon name="chart" class="w-3.5 h-3.5" /><p class="text-[11px] uppercase tracking-wider opacity-70 font-semibold text-brand-blue-darker">Total views</p></div>
      <p class="text-3xl font-bold">{total}</p>
      <span class:list={['text-[11px] font-bold px-1.5 py-0.5 rounded-full', deltaPct > 0 ? 'bg-emerald-50 text-emerald-700' : deltaPct < 0 ? 'bg-red-50 text-red-600' : 'bg-slate-100 text-slate-500']}>
        {deltaPct > 0 ? '▲' : deltaPct < 0 ? '▼' : '■'} {Math.abs(deltaPct)}% vs prev
      </span>
    </div>
    <div class="bg-white rounded-2xl border border-line p-4 shadow-sm">
      <div class="flex items-center gap-1.5 text-brand-blue/60 mb-1"><AdminIcon name="gauge" class="w-3.5 h-3.5" /><p class="text-[11px] uppercase tracking-wider opacity-70 font-semibold text-brand-blue-darker">Daily avg</p></div>
      <p class="text-3xl font-bold">{dailyAvg}</p>
    </div>
    <div class="bg-white rounded-2xl border border-line p-4 shadow-sm">
      <div class="flex items-center gap-1.5 text-brand-blue/60 mb-1"><AdminIcon name="calendar" class="w-3.5 h-3.5" /><p class="text-[11px] uppercase tracking-wider opacity-70 font-semibold text-brand-blue-darker">Busiest day</p></div>
      <p class="text-lg font-bold mt-1">{busiest ? busiest.day.slice(5) : '—'}</p>
      <p class="text-xs opacity-55">{busiest ? `${busiest.views} views` : ''}</p>
    </div>
    <div class="bg-white rounded-2xl border border-line p-4 shadow-sm">
      <div class="flex items-center gap-1.5 text-brand-blue/60 mb-1"><AdminIcon name="clock" class="w-3.5 h-3.5" /><p class="text-[11px] uppercase tracking-wider opacity-70 font-semibold text-brand-blue-darker">Period</p></div>
      <p class="text-3xl font-bold">{range.label}</p>
      <p class="text-xs opacity-55">cookie-free</p>
    </div>
  </div>

  <section class="bg-white rounded-2xl border border-line shadow-sm p-5 mb-6">
    <h2 class="text-sm font-bold mb-3">Views per day</h2>
    {range.single ? (
      <>
        {total === 0 ? <p class="text-sm opacity-50">No data yet.</p> : (
          <div class="flex items-end gap-[3px] h-24">
            {hourArr.map((v, h) => (
              <div class="flex-1 bg-brand-blue/70 hover:bg-brand-red rounded-t" style={`height:${Math.max(2, Math.round((v / maxHour) * 100))}%`} title={`${label12(h)}: ${v}`}></div>
            ))}
          </div>
        )}
        <div class="flex justify-between text-[10px] opacity-45 mt-1"><span>12a</span><span>6a</span><span>12p</span><span>6p</span><span>11p</span></div>
      </>
    ) : (
      <>
        {total === 0 ? <p class="text-sm opacity-50">No data yet.</p> : (
          <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="none" class="w-full" style={`height:${H}px`} aria-hidden="true">
            <path d={areaPath} fill="#2f6f9f" fill-opacity="0.1" />
            <path d={prevLinePath} fill="none" stroke="#9ca3af" stroke-dasharray="4 3" stroke-width="1.5" vector-effect="non-scaling-stroke" />
            <path d={linePath} fill="none" stroke="#2f6f9f" stroke-width="2" vector-effect="non-scaling-stroke" />
          </svg>
        )}
        <div class="flex justify-between text-[10px] opacity-45 mt-1"><span>{range.start.slice(5)}</span><span>{range.end.slice(5)}</span></div>
        <div class="flex items-center gap-4 mt-3 text-[11px] opacity-60">
          <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-0.5 bg-brand-blue"></span>This period</span>
          <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-0.5" style="background-image:repeating-linear-gradient(to right,#9ca3af 0 4px,transparent 4px 7px)"></span>Previous period</span>
        </div>
      </>
    )}
  </section>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
    <section class="bg-white rounded-2xl border border-line shadow-sm p-5">
      <h2 class="text-sm font-bold mb-3">Top pages</h2>
      {pages.length === 0 && <p class="text-sm opacity-50">No data yet.</p>}
      <div class="space-y-2.5">
        {pages.map(p => (
          <div>
            <div class="flex justify-between text-sm mb-0.5"><span class="truncate">{p.path}</span><span class="opacity-55 ml-2 shrink-0">{p.views}</span></div>
            <div class="h-1.5 bg-line rounded-full overflow-hidden"><div class="h-full bg-brand-blue rounded-full" style={`width:${Math.round((p.views / maxPage) * 100)}%`}></div></div>
          </div>
        ))}
      </div>
    </section>
    <section class="bg-white rounded-2xl border border-line shadow-sm p-5">
      <h2 class="text-sm font-bold mb-3">Referrers</h2>
      {refs.length === 0 && <p class="text-sm opacity-50">No data yet.</p>}
      <div class="space-y-1.5 text-sm">
        {refs.map(r => <div class="flex justify-between"><span class="truncate">{r.host}</span><span class="opacity-55 ml-2 shrink-0">{r.views}</span></div>)}
      </div>
    </section>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
    <section class="bg-white rounded-2xl border border-line shadow-sm p-5">
      <h2 class="text-sm font-bold mb-3">Channels</h2>
      {channels.length === 0 && <p class="text-sm opacity-50">No data yet.</p>}
      <div class="space-y-2.5">
        {channels.map(c => (
          <div>
            <div class="flex justify-between text-sm mb-0.5"><span class="truncate">{c.channel}</span><span class="opacity-55 ml-2 shrink-0">{c.views} ({Math.round((c.views / channelTotal) * 100)}%)</span></div>
            <div class="h-1.5 bg-line rounded-full overflow-hidden"><div class="h-full bg-brand-blue rounded-full" style={`width:${Math.round((c.views / maxChannel) * 100)}%`}></div></div>
          </div>
        ))}
      </div>
    </section>
    <section class="bg-white rounded-2xl border border-line shadow-sm p-5">
      <h2 class="text-sm font-bold mb-3">Entry pages</h2>
      <p class="text-xs opacity-50 -mt-2 mb-3">arrivals from external sites — cookie-free, so internal navigation isn't counted</p>
      {entries.length === 0 && <p class="text-sm opacity-50">No data yet.</p>}
      <div class="space-y-2.5">
        {entries.map(e => (
          <div>
            <div class="flex justify-between text-sm mb-0.5"><span class="truncate">{e.path}</span><span class="opacity-55 ml-2 shrink-0">{e.n}</span></div>
            <div class="h-1.5 bg-line rounded-full overflow-hidden"><div class="h-full bg-brand-blue rounded-full" style={`width:${Math.round((e.n / maxEntry) * 100)}%`}></div></div>
          </div>
        ))}
      </div>
    </section>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
    <section class="bg-white rounded-2xl border border-line shadow-sm p-5">
      <h2 class="text-sm font-bold mb-3">Countries</h2>
      {countries.length === 0 && <p class="text-sm opacity-50">No data yet.</p>}
      <div class="space-y-1.5 text-sm">
        {countries.map(c => <div class="flex justify-between"><span>{c.country || '—'}</span><span class="opacity-55">{c.views}</span></div>)}
      </div>
    </section>
    <section class="bg-white rounded-2xl border border-line shadow-sm p-5">
      <h2 class="text-sm font-bold mb-3">Devices</h2>
      {devices.length === 0 && <p class="text-sm opacity-50">No data yet.</p>}
      <div class="space-y-1.5 text-sm">
        {devices.map(d => <div class="flex justify-between"><span class="capitalize">{d.device}</span><span class="opacity-55">{d.views} ({Math.round((d.views / devTotal) * 100)}%)</span></div>)}
      </div>
    </section>
  </div>

  <section class="bg-white rounded-2xl border border-line shadow-sm p-4 mb-6">
    <p class="text-sm">
      <span class="font-bold">{funnel.views}</span> report-issue views →
      <span class="font-bold">{funnel.tickets}</span> tickets
      (<span class="font-bold">{funnel.rate ?? '—'}%</span>)
    </p>
    <p class="text-xs opacity-50 mt-0.5">views of /report-issue/ vs tickets submitted</p>
  </section>

  <section class="bg-white rounded-2xl border border-line shadow-sm p-5 mb-6">
    <h2 class="text-sm font-bold mb-3">Busiest hours <span class="font-normal opacity-45">(Eastern)</span></h2>
    <div class="flex items-end gap-[3px] h-24">
      {hourArr.map((v, h) => (
        <div class="flex-1 bg-brand-blue/70 hover:bg-brand-red rounded-t" style={`height:${Math.max(2, Math.round((v / maxHour) * 100))}%`} title={`${label12(h)}: ${v}`}></div>
      ))}
    </div>
    <div class="flex justify-between text-[10px] opacity-45 mt-1"><span>12a</span><span>6a</span><span>12p</span><span>6p</span><span>11p</span></div>

    <h2 class="text-sm font-bold mb-3 mt-5">Busiest weekday</h2>
    <div class="flex items-end gap-[3px] h-16">
      {weekdayArr.map((v, wd) => (
        <div class="flex-1 bg-brand-blue/70 hover:bg-brand-red rounded-t" style={`height:${Math.max(2, Math.round((v / maxWeekday) * 100))}%`} title={`${weekdayLabels[wd]}: ${v}`}></div>
      ))}
    </div>
    <div class="flex justify-between text-[10px] opacity-45 mt-1">
      {weekdayLabels.map(l => <span>{l}</span>)}
    </div>
  </section>

  <!-- Recent visits (live) -->
  <section class="bg-white rounded-2xl border border-line shadow-sm">
    <div class="px-5 py-3.5 border-b border-line flex items-center justify-between">
      <h2 class="text-sm font-bold">Recent visits</h2>
      <span class="text-[11px] opacity-45 flex items-center gap-1.5">
        <span class="relative flex w-1.5 h-1.5"><span class="absolute inline-flex w-full h-full rounded-full bg-emerald-400 opacity-75 animate-ping"></span><span class="relative inline-flex w-1.5 h-1.5 rounded-full bg-emerald-500"></span></span>
        Live · refreshes every 30s
      </span>
    </div>
    {recent.length === 0 ? <p class="px-5 py-8 text-sm text-center opacity-50">No visits yet.</p> : (
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-[10px] uppercase tracking-wider opacity-45 text-left">
              <th class="font-semibold px-5 py-2">Time</th>
              <th class="font-semibold px-3 py-2">Page</th>
              <th class="font-semibold px-3 py-2">Referrer</th>
              <th class="font-semibold px-3 py-2">Device</th>
              <th class="font-semibold px-5 py-2 text-right">Country</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-line">
            {recent.map(v => (
              <tr class="hover:bg-cream/50">
                <td class="px-5 py-2.5 whitespace-nowrap opacity-70">{visitTime(v.ts)}</td>
                <td class="px-3 py-2.5 max-w-[220px] truncate" title={v.path}>{v.path}</td>
                <td class="px-3 py-2.5 opacity-70 max-w-[140px] truncate">{v.referrer_host || 'direct'}</td>
                <td class="px-3 py-2.5 capitalize opacity-70">{v.device || '—'}</td>
                <td class="px-5 py-2.5 text-right opacity-70">{v.country || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </section>
</AdminLayout>

<script is:inline>
  // Gentle auto-refresh, only when the tab is visible. The period stays in the
  // URL query, so a reload preserves the selected range.
  setInterval(function () { if (document.visibilityState === 'visible') location.reload(); }, 30000);
</script>
