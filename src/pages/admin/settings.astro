---
export const prerender = false;

import AdminLayout from '../../components/admin/AdminLayout.astro';
import { getHelpdeskEnv, ADMIN_TIMEZONES, VAPID_PUBLIC_KEY } from '../../lib/helpdesk/env';
import { getSetting, getTimezone } from '../../lib/helpdesk/db';

const env = await getHelpdeskEnv();
const [aiEnabled, houseRules, timezone] = await Promise.all([
  getSetting(env.DB, 'ai_enabled'),
  getSetting(env.DB, 'house_rules'),
  getTimezone(env.DB),
]);
const enabled = aiEnabled !== '0'; // default on
const hasKey = !!(env as any).ANTHROPIC_API_KEY;
---
<AdminLayout title="Settings">
  <h1 class="text-2xl font-bold tracking-tight mb-5">Settings</h1>

  <section class="bg-white rounded-2xl border border-line shadow-sm p-5 mb-5 max-w-2xl">
    <h2 class="text-sm font-bold mb-1">General</h2>
    <p class="text-sm opacity-60 mb-4">Times shown on tickets, messages, and recent visits use this timezone.</p>
    <label class="text-xs font-bold uppercase tracking-wider text-brand-blue block mb-2">Timezone</label>
    <select id="timezone" class="w-full sm:w-80 border-[1.5px] border-line rounded-xl px-3.5 py-2.5 text-sm bg-white focus:border-brand-blue focus:outline-none">
      {ADMIN_TIMEZONES.map(tz => <option value={tz.value} selected={tz.value === timezone}>{tz.label}</option>)}
    </select>
  </section>

  <section class="bg-white rounded-2xl border border-line shadow-sm p-5 mb-5 max-w-2xl">
    <h2 class="text-sm font-bold mb-1">Notifications</h2>
    <p class="text-sm opacity-60 mb-4">Get a push on this device when a customer opens a ticket or replies. Requires the installed app (Add to Home Screen) on iPhone.</p>
    <div class="flex items-center gap-3" data-vapid={VAPID_PUBLIC_KEY}>
      <button id="pushBtn" class="bg-brand-blue text-white font-bold text-sm px-6 py-2.5 rounded-full disabled:opacity-40" disabled>Checking…</button>
      <span id="pushStatus" class="text-sm opacity-60" aria-live="polite"></span>
    </div>
  </section>

  <section class="bg-white rounded-2xl border border-line shadow-sm p-5 mb-5 max-w-2xl">
    <h2 class="text-sm font-bold mb-1">AI reply assistant</h2>
    <p class="text-sm opacity-60 mb-4">Drafts replies to repeat questions from your past answers. Nothing is ever sent without your approval.</p>

    {!hasKey && (
      <div class="bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 text-sm mb-4">
        No API key yet. Add a Worker secret named <code class="font-mono">ANTHROPIC_API_KEY</code> in the Cloudflare dashboard to turn this on.
      </div>
    )}

    <label class="flex items-center gap-3 mb-5 cursor-pointer">
      <input type="checkbox" id="aiEnabled" checked={enabled} class="w-5 h-5 accent-brand-blue" />
      <span class="text-sm font-semibold">Suggest replies automatically</span>
    </label>

    <label class="text-xs font-bold uppercase tracking-wider text-brand-blue block mb-2">House rules</label>
    <p class="text-xs opacity-55 mb-2">Hours, refund policy, pricing, anything the assistant should always know. Kept private.</p>
    <textarea id="houseRules" rows="8" maxlength="4000"
      class="w-full border-[1.5px] border-line rounded-xl px-3.5 py-3 text-sm focus:border-brand-blue focus:outline-none resize-y"
      placeholder="e.g. Refunds for machine failures within 7 days. Open 6am–11pm daily. Detergent vending by the door.">{houseRules ?? ''}</textarea>

    <div class="flex items-center gap-3 mt-3">
      <button id="saveBtn" disabled class="bg-brand-red text-white font-bold text-sm px-7 py-2.5 rounded-full disabled:opacity-40 disabled:cursor-not-allowed">Save</button>
      <span id="saveStatus" class="text-sm opacity-60" aria-live="polite"></span>
    </div>
  </section>
</AdminLayout>

<script>
  const enabledEl = document.getElementById('aiEnabled') as HTMLInputElement;
  const rulesEl = document.getElementById('houseRules') as HTMLTextAreaElement;
  const tzEl = document.getElementById('timezone') as HTMLSelectElement;
  const statusEl = document.getElementById('saveStatus')!;
  const saveBtn = document.getElementById('saveBtn') as HTMLButtonElement;

  // Save is enabled only when something differs from the loaded state.
  const initial = { enabled: enabledEl.checked, rules: rulesEl.value, tz: tzEl.value };
  const dirty = () =>
    enabledEl.checked !== initial.enabled || rulesEl.value !== initial.rules || tzEl.value !== initial.tz;
  const syncBtn = () => { saveBtn.disabled = !dirty(); };
  for (const el of [enabledEl, rulesEl, tzEl]) {
    el.addEventListener('input', syncBtn);
    el.addEventListener('change', syncBtn);
  }
  syncBtn();

  let saving = false;
  saveBtn.addEventListener('click', async () => {
    if (saving || !dirty()) return;
    saving = true; statusEl.textContent = 'Saving…';
    try {
      const res = await fetch('/api/admin/settings/', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ aiEnabled: enabledEl.checked, houseRules: rulesEl.value, timezone: tzEl.value }),
      });
      // Reload on success so every timestamp on the page re-renders in the new zone.
      if (res.ok) { statusEl.textContent = 'Saved ✓'; location.reload(); }
      else statusEl.textContent = 'Failed — try again.';
    } catch {
      statusEl.textContent = 'Failed — try again.';
    }
    saving = false;
  });
</script>

<script>
  const pushBtn = document.getElementById('pushBtn') as HTMLButtonElement;
  const pushStatus = document.getElementById('pushStatus')!;
  const vapidKey = (pushBtn.parentElement as HTMLElement).dataset.vapid!;

  function keyBytes(b64u: string): Uint8Array {
    const pad = '='.repeat((4 - (b64u.length % 4)) % 4);
    const bin = atob((b64u + pad).replace(/-/g, '+').replace(/_/g, '/'));
    return Uint8Array.from(bin, c => c.charCodeAt(0));
  }

  async function refresh() {
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
      pushBtn.disabled = true; pushBtn.textContent = 'Not available';
      pushStatus.textContent = 'On iPhone: install via Add to Home Screen first, then open the app.';
      return;
    }
    const reg = await navigator.serviceWorker.register('/admin-sw.js', { scope: '/admin/' });
    const sub = await reg.pushManager.getSubscription();
    pushBtn.disabled = false;
    if (sub) { pushBtn.textContent = 'Disable on this device'; pushStatus.textContent = 'Enabled ✓'; }
    else { pushBtn.textContent = 'Enable on this device'; pushStatus.textContent = ''; }
  }

  pushBtn.addEventListener('click', async () => {
    pushBtn.disabled = true;
    try {
      const reg = await navigator.serviceWorker.register('/admin-sw.js', { scope: '/admin/' });
      const existing = await reg.pushManager.getSubscription();
      if (existing) {
        await fetch('/api/admin/push-unsubscribe/', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ endpoint: existing.endpoint }) });
        await existing.unsubscribe();
      } else {
        const perm = await Notification.requestPermission();
        if (perm !== 'granted') { pushStatus.textContent = 'Permission was declined.'; await refresh(); return; }
        const sub = await reg.pushManager.subscribe({ userVisibleOnly: true, applicationServerKey: keyBytes(vapidKey) as BufferSource });
        const res = await fetch('/api/admin/push-subscribe/', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(sub.toJSON()) });
        if (!res.ok) { pushStatus.textContent = 'Failed to save — try again.'; await sub.unsubscribe(); }
      }
    } catch (e) {
      pushStatus.textContent = 'Failed — try again.';
    }
    await refresh();
  });

  refresh();
</script>
