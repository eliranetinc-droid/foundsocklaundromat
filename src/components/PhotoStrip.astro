---
// Three wide interior shots dedicated to the homepage strip.
// Files at /public/photos/inside-{1,2,3}.jpg
const availablePhotos = import.meta.glob('/public/photos/inside-{1,2,3}.jpg', { eager: false });
const photoSrcs = new Set(
  Object.keys(availablePhotos).map(k => k.replace('/public', ''))
);
const photos = [
  { src: '/photos/inside-1.jpg', alt: 'Big stainless steel folding tables, Soap Center, and Wi-Fi seating',  tint: 'from-amber-100 to-amber-300' },
  { src: '/photos/inside-2.jpg', alt: 'Inside the laundromat — washers on the left, dryers on the right',    tint: 'from-slate-300 to-slate-500' },
  { src: '/photos/inside-3.jpg', alt: 'Comfortable dining tables and chairs — work or relax with free Wi-Fi', tint: 'from-blue-200 to-brand-blue' },
].map(p => ({ ...p, exists: photoSrcs.has(p.src) }));
---
<section class="bg-cream">
  <div class="max-w-6xl mx-auto px-5 py-12">
    <p class="text-xs uppercase tracking-[0.25em] text-brand-blue font-bold mb-3">Inside the laundromat</p>
    <div class="flex gap-2">
      {photos.map((p, i) => (
        <div class={`flex-1 aspect-[3/4] md:aspect-[4/5] rounded-xl overflow-hidden bg-gradient-to-br ${p.tint} ${i === 1 ? 'md:flex-[1.3]' : ''}`}>
          {p.exists && (
            <img src={p.src} alt={p.alt} loading={i === 0 ? 'eager' : 'lazy'} decoding="async" class="w-full h-full object-cover" />
          )}
        </div>
      ))}
    </div>
  </div>
</section>
