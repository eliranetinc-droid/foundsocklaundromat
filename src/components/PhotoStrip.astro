---
import { Picture } from 'astro:assets';
import inside1 from '../assets/photos/inside-1.jpg';
import inside2 from '../assets/photos/inside-2.jpg';
import inside3 from '../assets/photos/inside-3.jpg';

const photos = [
  { img: inside1, alt: 'Row of LG large-capacity front-load washers, looking down the line', tint: 'from-slate-200 to-slate-400' },
  { img: inside2, alt: 'Inside the laundromat — washers on the left, dryers on the right',    tint: 'from-slate-300 to-slate-500' },
  { img: inside3, alt: 'Comfortable seating and folding area with free Wi-Fi',                  tint: 'from-blue-200 to-brand-blue' },
];
---
<section class="bg-cream">
  <div class="max-w-6xl mx-auto px-5 py-12">
    <p class="text-xs uppercase tracking-[0.25em] text-brand-blue font-bold mb-3">Inside the laundromat</p>
    <div class="flex gap-2">
      {photos.map((p, i) => (
        <div class={`flex-1 aspect-[3/4] md:aspect-[4/5] rounded-xl overflow-hidden bg-gradient-to-br ${p.tint} ${i === 1 ? 'md:flex-[1.3]' : ''}`}>
          <Picture src={p.img} formats={['avif', 'webp']} widths={[300, 500, 800]} sizes="(max-width: 768px) 33vw, 25vw" alt={p.alt} loading={i === 0 ? 'eager' : 'lazy'} class="w-full h-full object-cover" />
        </div>
      ))}
    </div>
  </div>
</section>
