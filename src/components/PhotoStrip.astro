---
// Three photo slots. If a photo is missing, fall back to a brand-colored block.
// Owner drops these in /public/photos/storefront.jpg, /machines.jpg, /interior.jpg
const photos = [
  { src: '/photos/storefront.jpg', alt: 'Outside The Found Sock Laundromat in Brighton, MA', tint: 'from-slate-300 to-slate-500' },
  { src: '/photos/machines.jpg',   alt: 'Brand-new front-load washers',                       tint: 'from-red-200 to-brand-red' },
  { src: '/photos/interior.jpg',   alt: 'Clean folding tables and seating area',              tint: 'from-blue-200 to-brand-blue' },
];
---
<section class="bg-cream">
  <div class="max-w-6xl mx-auto px-5 py-12">
    <p class="text-xs uppercase tracking-[0.25em] text-brand-blue font-bold mb-3">Inside the laundromat</p>
    <div class="flex gap-2">
      {photos.map((p, i) => (
        <div class={`flex-1 aspect-[4/5] rounded-xl overflow-hidden bg-gradient-to-br ${p.tint} ${i === 1 ? 'md:flex-[1.3]' : ''}`}>
          <img src={p.src} alt={p.alt} loading={i === 0 ? 'eager' : 'lazy'} decoding="async" class="w-full h-full object-cover" onerror="this.style.display='none'" />
        </div>
      ))}
    </div>
  </div>
</section>
