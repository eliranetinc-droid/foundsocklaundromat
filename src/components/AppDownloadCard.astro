      <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M3.6 1.45a.5.5 0 0 0-.6.49v20.12a.5.5 0 0 0 .6.49l13.16-9.81a.93.93 0 0 0 0-1.5L3.6 1.45zm14.5 8.4l2.39 1.41a.94.94 0 0 1 0 1.5l-2.39 1.41-3.06-2.16 3.06-2.16zm-2.34 4.46-3 2.13L4.62 22.5l11.14-8.19zm-11.14-12 8.14 5.95 3 2.13L4.62 1.5z"/></svg>
      Google Play
