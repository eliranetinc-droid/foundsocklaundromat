---
interface Props { kind: 'issue' | 'general'; }
const { kind } = Astro.props;
const isIssue = kind === 'issue';
---
<form class="space-y-5 max-w-lg" data-contact-form data-kind={kind}>
  <div>
    <label class="text-xs font-bold text-brand-blue-darker block mb-1.5 tracking-wide">Your name</label>
    <input type="text" name="name" required maxlength="100" class="w-full border-[1.5px] border-line rounded-xl px-3.5 py-3 text-sm focus:border-brand-blue focus:outline-none" />
  </div>
  <div>
    <label class="text-xs font-bold text-brand-blue-darker block mb-1.5 tracking-wide">Your email</label>
    <input type="email" name="email" required class="w-full border-[1.5px] border-line rounded-xl px-3.5 py-3 text-sm focus:border-brand-blue focus:outline-none" />
  </div>
  <div>
    <label class="text-xs font-bold text-brand-blue-darker block mb-1.5 tracking-wide">{isIssue ? "What's wrong?" : 'How can we help?'}</label>
    <textarea name="message" required rows="5" maxlength="5000" placeholder={isIssue ? 'Which machine? What happened?' : 'Type your message here...'} class="w-full border-[1.5px] border-line rounded-xl px-3.5 py-3 text-sm focus:border-brand-blue focus:outline-none resize-y"></textarea>
    <p class="text-xs opacity-55 mt-1">We respond within a few hours during open hours.</p>
  </div>
  <button type="submit" class="bg-brand-red text-white font-bold text-sm px-7 py-3.5 rounded-full shadow-[0_4px_14px_rgba(200,0,20,0.35)] disabled:opacity-50">
    Send →
  </button>
  <div data-status class="text-sm" aria-live="polite"></div>
</form>
<script>
  document.querySelectorAll<HTMLFormElement>('[data-contact-form]').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
      const status = form.querySelector<HTMLElement>('[data-status]')!;
      const kind = form.dataset.kind!;
      const data = Object.fromEntries(new FormData(form));
      btn.disabled = true;
      status.textContent = 'Sending...';

      try {
        const res = await fetch('/api/submit-ticket/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...data, type: kind }),
        });
        if (!res.ok) throw new Error(`status ${res.status}`);
        status.textContent = "✓ Got it. We'll reply by email shortly.";
        status.className = 'text-sm text-emerald-700';
        form.reset();
      } catch (err) {
        status.textContent = "Couldn't send. Email support@foundsocklaundromat.com directly.";
        status.className = 'text-sm text-brand-red';
      } finally {
        btn.disabled = false;
      }
    });
  });
</script>
