---
const features = [
  {
    title: 'Start machines from your phone',
    body: 'Download our app (CCI/FasCard), scan the machine, tap to start. See open machines in real time before you come in.',
    cta: { href: '/app', label: 'See the app' },
    icon: 'phone',
  },
  {
    title: 'Card, Apple Pay, or loyalty card',
    body: 'No quarters, no hunting for change. Cash welcome too — load it onto a loyalty card at our touchscreen kiosk.',
    icon: 'card',
  },
  {
    title: 'Spotless, every day',
    body: 'We clean the floors, folding tables, and machines daily. The space looks brand new because we treat it like one.',
    icon: 'sparkle',
  },
  {
    title: 'Free Wi-Fi & comfy seating',
    body: 'TV, fast Wi-Fi, and a clean place to work or read while you wait.',
    icon: 'wifi',
  },
  {
    title: '10% cashback rewards',
    body: 'Every dollar you spend earns cashback toward your next wash. The card never expires.',
    cta: { href: '/loyalty', label: 'How it works' },
    icon: 'gift',
  },
];

// Inline icons per spec §6 — Lucide-style SVG path data
const ICONS: Record<string, string> = {
  phone: '<rect x="7" y="2" width="10" height="20" rx="2"/><circle cx="12" cy="18" r="0.5"/>',
  card:  '<rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 10h18"/><path d="M7 15h3"/>',
  sparkle: '<path d="M12 2l2 6h6l-5 4 2 7-7-4-7 4 2-7-5-4h6z"/>',
  wifi:  '<path d="M5 12a14 14 0 0 1 14 0M8.5 15.5a8 8 0 0 1 7 0M12 19h.01"/>',
  gift:  '<circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-6"/>',
};
---
<section class="max-w-3xl mx-auto px-5 py-14 md:py-20">
  <p class="text-xs uppercase tracking-[0.25em] text-brand-blue font-bold mb-7">Why customers choose us</p>
  <ul class="space-y-7">
    {features.map(feat => (
      <li class="flex gap-4 items-start">
        <div class="w-10 h-10 border-[1.5px] border-brand-blue-darker rounded-[10px] bg-cream flex-shrink-0 flex items-center justify-center relative">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-4.5 h-4.5 text-brand-blue-darker" set:html={ICONS[feat.icon]} />
          <span class="absolute -top-1 -right-1 w-2 h-2 rounded-full bg-brand-red" aria-hidden="true"></span>
        </div>
        <div class="flex-1">
          <h3 class="font-semibold text-base mb-1">{feat.title}</h3>
          <p class="text-sm text-brand-blue-darker/60 leading-relaxed">{feat.body}</p>
          {feat.cta && <a href={feat.cta.href} class="inline-block text-xs font-semibold text-brand-red border-b-2 border-brand-red mt-2 pb-0.5">{feat.cta.label} →</a>}
        </div>
      </li>
    ))}
  </ul>
</section>
