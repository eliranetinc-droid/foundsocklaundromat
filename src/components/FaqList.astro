---
import faqs from '../data/faqs.json';
---
<dl class="space-y-2">
  {faqs.map(faq => (
    <details class="bg-cream rounded-xl group">
      <summary class="cursor-pointer list-none p-5 font-semibold text-base flex justify-between items-center gap-3">
        <span>{faq.q}</span>
        <span class="text-brand-red text-xl group-open:rotate-45 transition-transform">+</span>
      </summary>
      <div class="px-5 pb-5 -mt-1 text-sm opacity-75 leading-relaxed">{faq.a}</div>
    </details>
  ))}
</dl>
