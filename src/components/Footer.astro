---
import { getBusiness } from '../lib/business';
const b = getBusiness();
---
<footer class="bg-brand-blue-darker text-white">
  <div class="max-w-6xl mx-auto px-5 py-10">
    <div class="inline-block bg-white p-2.5 rounded-lg mb-6">
      <img src="/brand/logo-horizontal.png" alt={b.name} width="160" height="29" />
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-7 text-sm">
      <div>
        <h4 class="text-xs uppercase tracking-widest opacity-55 font-semibold mb-3">Visit</h4>
        <p class="opacity-75 leading-relaxed">
          {b.address.streetAddress}<br/>
          {b.address.addressLocality}, {b.address.addressRegion} {b.address.postalCode}<br/>
          Daily {b.hours.open.replace(':00', '')} AM – 11 PM
        </p>
      </div>
      <div>
        <h4 class="text-xs uppercase tracking-widest opacity-55 font-semibold mb-3">Services</h4>
        <ul class="space-y-2 opacity-75">
          <li><a href="/pricing">Pricing</a></li>
          <li><a href="/loyalty">Loyalty</a></li>
          <li><a href="/app">App</a></li>
          <li><a href="/gallery">Gallery</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs uppercase tracking-widest opacity-55 font-semibold mb-3">Help</h4>
        <ul class="space-y-2 opacity-75">
          <li><a href="/faq">FAQ</a></li>
          <li><a href="/contact">Contact</a></li>
          <li><a href="/report-issue">Report issue</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs uppercase tracking-widest opacity-55 font-semibold mb-3">Read</h4>
        <ul class="space-y-2 opacity-75">
          <li><a href="/about">About</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </div>
    </div>
    <p class="text-xs opacity-45 mt-10 pt-6 border-t border-white/10">
      © 2015–2026 {b.name}. Self-service laundromat in {b.address.addressLocality}, {b.address.addressRegion}.
    </p>
  </div>
</footer>
